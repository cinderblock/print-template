{
  "name": "print-template",
  "private": true,
  "description": "Print onto physical media — envelopes, labels, and more — from your browser.",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview --outDir build/client",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "react-router typegen && tsc",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@react-router/node": "^8.1.0",
    "isbot": "^5.1.44",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^8.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.57.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2"
  }
}
